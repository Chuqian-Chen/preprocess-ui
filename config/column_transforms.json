{
  "tables": {
    "LIS.csv": {
      "output": "LIS_clean.csv",
      "columns": [
        {"field": "EXAMINAIM", "action": "rename", "target": "检验套餐", "note": "strip markers"},
        {"field": "CHINESENAME", "action": "rename", "target": "检验项目", "note": "TESTID字典"},
        {"field": "定量+定性+UNIT", "action": "merge", "target": "结果", "note": "定量优先拼接单位"},
        {"field": "UNIT", "action": "dictionary", "target": "单位", "note": "LIS_TESTID单位字典"},
        {"field": "参考值+结果值", "action": "derive", "target": "结果判断", "note": "偏高/偏低/正常"},
        {"field": "PATTYPE", "action": "drop", "target": "", "note": "用住院号加住院次/门诊就诊号区分"},
        {"field": "采样时间", "action": "normalize_date", "target": "采样时间", "note": ""}
      ]
    },
    "住院药品医嘱.csv": {
      "output": "住院医嘱_clean.csv",
      "columns": [
        {"field": "医嘱名称", "action": "normalize", "target": "医嘱名称", "note": "药品名标准化"},
        {"field": "规格", "action": "strip", "target": "规格", "note": "去尾部空格"},
        {"field": "开嘱时间/停嘱时间", "action": "normalize_date", "target": "医嘱开始/结束日期", "note": ""},
        {"field": "医嘱号", "action": "keep", "target": "医嘱号", "note": "v4从raw补全缺失"}
      ]
    },
    "住院就诊信息HIS.csv+电子病历.csv": {
      "output": "住院就诊信息_clean.csv",
      "columns": [
        {"field": "HIS+EMR", "action": "merge", "target": "六列诊断+日期", "note": "PATIENTID=主索引"},
        {"field": "出院结果诊断", "action": "rebuild", "target": "出院结果诊断", "note": "主要+其他"},
        {"field": "AGE+AGE_HIS", "action": "merge", "target": "年龄", "note": "优先AGE_HIS"}
      ]
    },
    "门诊就诊信息.csv": {
      "output": "门诊就诊信息_clean.csv",
      "columns": [
        {"field": "ICD", "action": "backfill", "target": "ICD", "note": "诊断配对推断4334行"},
        {"field": "诊断", "action": "keep", "target": "诊断", "note": ""}
      ]
    },
    "功能科检查+医学影像科检查.csv": {
      "output": "检查_US/CT/XRAY/MRI.csv",
      "columns": [
        {"field": "检查项目名称", "action": "synonym_merge", "target": "检查项目名称", "note": "同义映射"},
        {"field": "模态", "action": "split_by", "target": "US/CT/XRAY/MRI", "note": "按模态拆表"}
      ]
    },
    "LIS-细菌结果.csv": {
      "output": "细菌结果_clean.csv",
      "columns": [
        {"field": "数量", "action": "split_qc", "target": "数量质控分类", "note": "独立质控表"},
        {"field": "BIONAME", "action": "rename", "target": "名称", "note": ""}
      ]
    },
    "LIS-药敏结果.csv": {
      "output": "细菌药敏结果_clean.csv",
      "columns": [
        {"field": "MIC结果", "action": "keep", "target": "MIC结果", "note": "分列"},
        {"field": "KB结果", "action": "keep", "target": "KB结果", "note": "分列"}
      ]
    }
  }
}
